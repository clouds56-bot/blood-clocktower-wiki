{
  "name": "game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx tests/**/*.test.ts",
    "test:coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=lcov --import tsx tests/**/*.test.ts > coverage/lcov.info",
    "example": "tsx ./examples/usage.ts",
    "cli": "tsx ./src/cli/repl.ts"
  },
  "dependencies": {
    "cli-table3": "^0.6.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
