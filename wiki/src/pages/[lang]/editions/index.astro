---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { defaultLang, useTranslations, getBasePath, getSupportedLangs } from '../../../i18n/utils';

const supportedLangCodes = getSupportedLangs().map(({ code }) => code);

export function getStaticPaths() {
  return getSupportedLangs().map(({ code }) => ({ params: { lang: code } }));
}

const editions = await getCollection('editions');
const { lang } = Astro.params;
const validatedLang = lang && supportedLangCodes.includes(lang) ? lang : defaultLang;
const { t } = useTranslations(validatedLang);
const base = getBasePath(validatedLang);

const getCharCount = (edition: any) => {
  const chars = edition.data.characters || {};
  const townsfolk = chars.townsfolk?.length || 0;
  const outsider = chars.outsider?.length || 0;
  const minion = chars.minion?.length || 0;
  const demon = chars.demon?.length || 0;
  return { townsfolk, outsider, minion, demon, total: townsfolk + outsider + minion + demon };
};
---

<BaseLayout title={`${t('editions.title')} | Wiki`}>
  <div class="mb-8">
    <p class="uppercase tracking-[0.4em] text-xs text-[color:var(--ink-200)]">{validatedLang === 'cn' ? '剧本列表' : 'Game Editions'}</p>
    <h1 class="font-display text-4xl sm:text-5xl mt-3 mb-3 text-[color:var(--ink-50)]">
      {t('editions.title')}
    </h1>
    <p class="text-base sm:text-lg text-[color:var(--ink-200)] max-w-2xl">
      {t('editions.subtitle')}
    </p>
  </div>

  <div class="mb-6 sticky top-[64px] z-10">
    <div class="surface-panel rounded-2xl px-4 py-4 sm:px-6 sm:py-5">
      <div class="flex flex-col gap-4">
        <div class="flex flex-col sm:flex-row gap-3 items-stretch sm:items-center">
          <div class="flex-1 relative">
            <input
              type="text"
              id="edition-search"
              placeholder={validatedLang === 'cn' ? '搜索剧本...' : 'Search editions...'}
              class="w-full pl-11 pr-4 py-3 rounded-full bg-[color:var(--bg-800)] border border-[rgba(215,180,106,0.35)] text-[color:var(--ink-50)] placeholder:text-[color:var(--ink-200)] focus:outline-none focus:ring-2 focus:ring-[color:var(--accent-gold)] shadow-sm transition"
            />
            <svg class="w-5 h-5 absolute left-4 top-3.5 text-[color:var(--ink-200)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>
          <div class="flex gap-2">
            <button data-type="all" class="filter-btn active px-4 py-2 rounded-full text-sm font-semibold bg-[color:var(--accent-gold)] text-[#1a141f] shadow-sm transition">
              {validatedLang === 'cn' ? '全部' : 'All'}
            </button>
          </div>
        </div>
        <div class="flex flex-wrap gap-2" id="edition-filters">
          <button data-type="trouble_brewing" class="filter-btn px-4 py-2 text-sm rounded-full bg-[color:var(--bg-800)] text-[color:var(--ink-200)] border border-[rgba(215,180,106,0.25)] font-medium shadow-sm transition hover:text-[color:var(--accent-gold)]">
            {validatedLang === 'cn' ? '暗流涌动' : 'Trouble Brewing'}
          </button>
          <button data-type="bad_moon_rising" class="filter-btn px-4 py-2 text-sm rounded-full bg-[color:var(--bg-800)] text-[color:var(--ink-200)] border border-[rgba(215,180,106,0.25)] font-medium shadow-sm transition hover:text-[color:var(--accent-gold)]">
            {validatedLang === 'cn' ? '黯月初升' : 'Bad Moon Rising'}
          </button>
          <button data-type="sects_violets" class="filter-btn px-4 py-2 text-sm rounded-full bg-[color:var(--bg-800)] text-[color:var(--ink-200)] border border-[rgba(215,180,106,0.25)] font-medium shadow-sm transition hover:text-[color:var(--accent-gold)]">
            {validatedLang === 'cn' ? '梦殒春宵' : 'Sects & Violets'}
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {editions.map(edition => {
      const name = edition.data.name?.[validatedLang] || edition.data.name?.en || edition.id;
      const description = edition.data.description?.[validatedLang] || edition.data.description?.en || '';
      const counts = getCharCount(edition);

      return (
        <a
          href={`${base}/editions/${edition.id}`}
          class="edition-card group block surface-panel rounded-2xl overflow-hidden hover:-translate-y-1 transition-all duration-300"
          data-edition={edition.id}
          data-name={name.toLowerCase()}
          data-subtitle={description.toLowerCase()}
        >
          <div class="p-6">
            <h2 class="font-display text-2xl sm:text-3xl text-[color:var(--ink-50)] mb-3">
              {name}
            </h2>
            <p class="text-sm text-[color:var(--ink-200)] line-clamp-3 mb-4 leading-relaxed">
              {description}
            </p>
            <div class="flex flex-wrap gap-2 text-xs uppercase tracking-widest">
              <span class="px-3 py-1 rounded-full border border-[rgba(90,162,255,0.4)] text-[color:var(--accent-blue)]">
                {counts.townsfolk} {validatedLang === 'cn' ? '镇民' : 'Townsfolk'}
              </span>
              <span class="px-3 py-1 rounded-full border border-[rgba(90,162,255,0.4)] text-[color:var(--accent-blue)]">
                {counts.outsider} {validatedLang === 'cn' ? '外来者' : 'Outsiders'}
              </span>
              <span class="px-3 py-1 rounded-full border border-[rgba(255,90,90,0.4)] text-[color:var(--accent-red)]">
                {counts.minion} {validatedLang === 'cn' ? '爪牙' : 'Minions'}
              </span>
              <span class="px-3 py-1 rounded-full border border-[rgba(255,90,90,0.4)] text-[color:var(--accent-red)]">
                {counts.demon} {validatedLang === 'cn' ? '恶魔' : 'Demons'}
              </span>
            </div>
          </div>
        </a>
      );
    })}
  </div>

  <div id="no-results" class="hidden text-center py-12">
    <p class="text-lg text-[color:var(--ink-200)]">{validatedLang === 'cn' ? '未找到匹配的剧本。' : 'No editions found matching your criteria.'}</p>
  </div>
</BaseLayout>

<script>
  function setupFilters() {
    const searchInput = document.getElementById('edition-search') as HTMLInputElement;
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.edition-card');
    const noResults = document.getElementById('no-results');

    if (!searchInput) return;

    let currentFilter = 'all';
    let currentSearch = '';

    function filterCards() {
      let visibleCount = 0;

      cards.forEach((card) => {
        const el = card as HTMLElement;
        const editionId = el.getAttribute('data-edition') || '';
        const name = el.getAttribute('data-name') || '';
        const subtitle = el.getAttribute('data-subtitle') || '';

        const matchesType = currentFilter === 'all' || editionId === currentFilter;
        const matchesSearch = name.includes(currentSearch) || subtitle.includes(currentSearch);

        if (matchesType && matchesSearch) {
          el.style.display = 'block';
          visibleCount++;
        } else {
          el.style.display = 'none';
        }
      });

      if (noResults) {
        noResults.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    }

    searchInput.addEventListener('input', (e) => {
      currentSearch = (e.target as HTMLInputElement).value.toLowerCase();
      filterCards();
    });

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const editionId = target.getAttribute('data-type');

        if (editionId) {
          currentFilter = editionId;

          filterBtns.forEach((b) => {
            b.classList.remove('bg-[color:var(--accent-gold)]', 'text-[#1a141f]');
            b.classList.add('bg-[color:var(--bg-800)]', 'text-[color:var(--ink-200)]');
          });

          target.classList.remove('bg-[color:var(--bg-800)]', 'text-[color:var(--ink-200)]');
          target.classList.add('bg-[color:var(--accent-gold)]', 'text-[#1a141f]');

          filterCards();
        }
      });
    });
  }

  setupFilters();
  document.addEventListener('astro:page-load', setupFilters);
</script>
