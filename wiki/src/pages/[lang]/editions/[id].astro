---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { defaultLang, useTranslations, getBasePath, getSupportedLangs, getAssetUrl } from '../../../i18n/utils';

const supportedLangCodes = getSupportedLangs().map(({ code }) => code);

export async function getStaticPaths() {
  const editions = await getCollection('editions');
  return getSupportedLangs().flatMap(({ code }) =>
    editions.map((edition) => ({
      params: { lang: code, id: edition.id },
      props: { edition },
    }))
  );
}

const { edition } = Astro.props;
const data = edition.data;
const { lang } = Astro.params;
const validatedLang = lang && supportedLangCodes.includes(lang) ? lang : defaultLang;
const { t } = useTranslations(validatedLang);
const base = getBasePath(validatedLang);

const characters = await getCollection('characters');
const characterMap = new Map(characters.map((c) => [c.id, c]));

const typeLabels: Record<string, any> = {
  townsfolk: { en: 'Townsfolk', cn: '镇民' },
  outsider: { en: 'Outsiders', cn: '外来者' },
  minion: { en: 'Minions', cn: '爪牙' },
  demon: { en: 'Demons', cn: '恶魔' },
  traveller: { en: 'Travellers', cn: '旅行者' },
  fabled: { en: 'Fabled', cn: '传奇' },
  loric: { en: 'Loric', cn: 'Loric' },
};

const typeBadgeLabels: Record<string, any> = {
  townsfolk: { en: 'Townsfolk', cn: '镇民' },
  outsider: { en: 'Outsider', cn: '外来者' },
  minion: { en: 'Minion', cn: '爪牙' },
  demon: { en: 'Demon', cn: '恶魔' },
  traveller: { en: 'Traveller', cn: '旅行者' },
  fabled: { en: 'Fabled', cn: '传奇' },
  loric: { en: 'Loric', cn: 'Loric' },
};

const getTypeLabel = (type: string) => typeLabels[type]?.[validatedLang] || type;
const getTypeBadgeLabel = (type: string) => typeBadgeLabels[type]?.[validatedLang] || type;
const isGoodType = (type: string) =>
  type === 'townsfolk' || type === 'outsider' || type === 'traveller' || type === 'fabled';

const getCharacterPath = (type: string, id: string) => `${type}/${id}`;

const resolveCharacterByNightOrderId = (entryId: string) => {
  const direct = characterMap.get(entryId);
  if (direct) return direct;

  const bySuffix = Array.from(characterMap.values()).find((c) => {
    const parts = c.id.split('/');
    return parts[parts.length - 1] === entryId;
  });

  return bySuffix || null;
};

const resolveImageSrc = (c: any) => {
  const imgField = c.data?.image;
  const id = c.data?.id || c.id.split('/').pop();
  let p = imgField || `assets/tokens/${id}.png`;
  const hasExt = /\.\w{2,5}$/.test(p);
  let candidate = hasExt ? p : `${p}.png`;
  candidate = candidate.replace(/^\/*data\/assets\//, 'assets/');
  return getAssetUrl(candidate);
};
---

<BaseLayout title={`${data.name?.[validatedLang] || data.name?.en || edition.id} | Wiki`}>
  <div class="mb-6">
    <a href={`${base}/editions`} class="text-[color:var(--ink-200)] hover:text-[color:var(--accent-gold)] transition">{t('editions.back')}</a>
  </div>

  <div class="surface-panel rounded-3xl p-6 sm:p-8">
    <header class="mb-8">
      <p class="uppercase tracking-[0.35em] text-xs text-[color:var(--ink-200)]">{validatedLang === 'cn' ? '剧本' : 'Game Edition'}</p>
      <h1 class="font-display text-4xl sm:text-5xl mt-3 text-[color:var(--ink-50)]">
        {data.name?.[validatedLang] || data.name?.en}
      </h1>
      {validatedLang === 'cn' && data.name?.en && <div class="text-lg text-[color:var(--ink-200)] mt-2">{data.name.en}</div>}
      {validatedLang === 'en' && data.name?.cn && <div class="text-lg text-[color:var(--ink-200)] mt-2">{data.name.cn}</div>}
    </header>

    {data.description?.[validatedLang] && (
      <section class="mb-10">
        <div class="rounded-2xl border border-[rgba(215,180,106,0.35)] bg-[color:var(--bg-800)] p-5 sm:p-6">
          <p class="text-base sm:text-lg text-[color:var(--ink-50)] leading-relaxed">{data.description?.[validatedLang]}</p>
          {data.description?.[validatedLang === 'en' ? 'cn' : 'en'] && (
            <p class="mt-3 text-[color:var(--ink-200)]">{data.description?.[validatedLang === 'en' ? 'cn' : 'en']}</p>
          )}
        </div>
      </section>
    )}

    <section class="mb-10">
      <h2 class="font-display text-2xl mb-6 text-[color:var(--ink-50)] border-b soft-divider pb-2">{t('editions.characters')}</h2>

      {['townsfolk', 'outsider', 'minion', 'demon'].map((type) => {
        const chars = data.characters?.[type] || [];
        if (chars.length === 0) return null;

        return (
          <div class="mb-8">
            <h3 class="font-display text-xl mb-4 text-[color:var(--ink-50)]">{getTypeLabel(type)}</h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
              {chars.map((charId: string) => {
                const fullCharId = getCharacterPath(type, charId);
                const char = characterMap.get(fullCharId) || characterMap.get(charId);
                const charName = char?.data.name?.[validatedLang] || char?.data.name?.en || charId;
                const charSubtitle = validatedLang === 'en' ? char?.data.name?.cn : char?.data.name?.en;
                const summary = char?.data.summary?.[validatedLang] || char?.data.summary?.en || '';
                const imageSrc = char ? resolveImageSrc(char) : '';
                const isGood = isGoodType(type);
                const charPath = char ? char.id : fullCharId;

                return (
                  <a
                    href={`${base}/characters/${charPath}`}
                    class="character-card group block surface-panel rounded-2xl overflow-hidden hover:-translate-y-1 transition-all duration-300"
                  >
                    <div class="px-4 pt-4">
                      <div class={`token-ring mx-auto w-20 h-20 sm:w-24 sm:h-24 rounded-full overflow-hidden bg-[color:var(--bg-700)] flex items-center justify-center border ${isGood ? 'border-[rgba(90,162,255,0.6)]' : 'border-[rgba(255,90,90,0.6)]'}`}>
                        {imageSrc && <img src={imageSrc} alt={charName} loading="lazy" class="w-full h-full object-cover" onerror="this.style.display='none'" />}
                      </div>
                    </div>
                    <div class="px-4 pb-4 pt-3 text-center">
                      <h4 class="font-display text-base sm:text-lg text-[color:var(--ink-50)] leading-tight">{charName}</h4>
                      {charSubtitle && <p class="text-xs sm:text-sm text-[color:var(--ink-200)] mt-1">{charSubtitle}</p>}
                      <div class="mt-2 flex items-center justify-center gap-2 text-xs uppercase tracking-widest text-[color:var(--ink-200)]">
                        <span class={`px-2 py-1 rounded-full border ${isGood ? 'border-[rgba(90,162,255,0.6)] text-[color:var(--accent-blue)]' : 'border-[rgba(255,90,90,0.6)] text-[color:var(--accent-red)]'}`}>
                          {getTypeBadgeLabel(type)}
                        </span>
                      </div>
                      {summary && <p class="mt-2 text-xs text-[color:var(--ink-200)] line-clamp-2 leading-relaxed">{summary}</p>}
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        );
      })}
    </section>

    {data.night_order && (data.night_order.first_night || data.night_order.other_nights) && (
      <section class="mb-10">
        <h2 class="font-display text-2xl mb-6 text-[color:var(--ink-50)] border-b soft-divider pb-2">{validatedLang === 'cn' ? '夜晚顺序' : 'Night Order'}</h2>

        {data.night_order.first_night && data.night_order.first_night.length > 0 && (
          <div class="mb-6">
            <h3 class="font-display text-xl mb-4 text-[color:var(--ink-50)]">{t('editions.first_night')}</h3>
            <div class="space-y-2">
              {data.night_order.first_night.map((itemId: string, idx: number) => {
                const char = resolveCharacterByNightOrderId(itemId);
                const charType = char?.data?.type || 'special';
                const charName = char?.data.name?.[validatedLang] || char?.data.name?.en || itemId;
                const typeLabel = getTypeLabel(charType);
                const isGood = isGoodType(charType);
                const charPath = char ? char.id : getCharacterPath(charType, itemId);

                return (
                  <div class="flex items-center gap-3 surface-panel rounded-xl p-3 border border-[rgba(215,180,106,0.2)]">
                    <div class="flex-shrink-0 w-8 h-8 rounded-full bg-[color:var(--bg-700)] flex items-center justify-center text-sm font-semibold text-[color:var(--accent-gold)] border border-[rgba(215,180,106,0.4)]">
                      {idx + 1}
                    </div>
                    <div class="flex-1 min-w-0">
                      <a href={`${base}/characters/${charPath}`} class="text-[color:var(--ink-50)] hover:text-[color:var(--accent-gold)] transition font-medium">
                        {charName}
                      </a>
                    </div>
                    <span class={`text-xs uppercase tracking-wider px-2 py-1 rounded-full border ${isGood ? 'border-[rgba(90,162,255,0.4)] text-[color:var(--accent-blue)]' : 'border-[rgba(255,90,90,0.4)] text-[color:var(--accent-red)]'}`}>
                      {typeLabel}
                    </span>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {data.night_order.other_nights && data.night_order.other_nights.length > 0 && (
          <div>
            <h3 class="font-display text-xl mb-4 text-[color:var(--ink-50)]">{t('editions.other_nights')}</h3>
            <div class="space-y-2">
              {data.night_order.other_nights.map((itemId: string, idx: number) => {
                const char = resolveCharacterByNightOrderId(itemId);
                const charType = char?.data?.type || 'special';
                const charName = char?.data.name?.[validatedLang] || char?.data.name?.en || itemId;
                const typeLabel = getTypeLabel(charType);
                const isGood = isGoodType(charType);
                const charPath = char ? char.id : getCharacterPath(charType, itemId);

                return (
                  <div class="flex items-center gap-3 surface-panel rounded-xl p-3 border border-[rgba(215,180,106,0.2)]">
                    <div class="flex-shrink-0 w-8 h-8 rounded-full bg-[color:var(--bg-700)] flex items-center justify-center text-sm font-semibold text-[color:var(--accent-gold)] border border-[rgba(215,180,106,0.4)]">
                      {idx + 1}
                    </div>
                    <div class="flex-1 min-w-0">
                      <a href={`${base}/characters/${charPath}`} class="text-[color:var(--ink-50)] hover:text-[color:var(--accent-gold)] transition font-medium">
                        {charName}
                      </a>
                    </div>
                    <span class={`text-xs uppercase tracking-wider px-2 py-1 rounded-full border ${isGood ? 'border-[rgba(90,162,255,0.4)] text-[color:var(--accent-blue)]' : 'border-[rgba(255,90,90,0.4)] text-[color:var(--accent-red)]'}`}>
                      {typeLabel}
                    </span>
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </section>
    )}

    {data.source_url && data.source_url[validatedLang] && (
      <div class="mt-10 text-sm text-[color:var(--ink-200)] text-right">
        <a href={data.source_url[validatedLang]} target="_blank" rel="noopener noreferrer" class="hover:text-[color:var(--accent-gold)] underline">
          {t('editions.view_official')}
        </a>
      </div>
    )}
  </div>
</BaseLayout>
