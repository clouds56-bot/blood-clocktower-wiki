---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CharacterList from '../../../components/CharacterList.astro';
import { defaultLang, useTranslations, getSupportedLangs, getBasePath } from '../../../i18n/utils';

const supportedLangCodes = getSupportedLangs().map(({ code }) => code);

export function getStaticPaths() {
  return getSupportedLangs().map(({ code }) => ({ params: { lang: code } }));
}

const characters = await getCollection('characters');
const { lang } = Astro.params;
const validatedLang = lang && supportedLangCodes.includes(lang) ? lang : defaultLang;
const { t } = useTranslations(validatedLang);
const base = getBasePath(validatedLang);

const typeOrder = ['townsfolk', 'outsider', 'minion', 'demon', 'traveller', 'fabled', 'loric'];
const typeLabels: Record<string, Record<'en' | 'cn', string>> = {
  townsfolk: { en: 'Townsfolk', cn: '镇民' },
  outsider: { en: 'Outsiders', cn: '外来者' },
  minion: { en: 'Minions', cn: '爪牙' },
  demon: { en: 'Demons', cn: '恶魔' },
  traveller: { en: 'Travellers', cn: '旅行者' },
  fabled: { en: 'Fabled', cn: '传奇' },
  loric: { en: 'Loric', cn: 'Loric' },
};

const counts = typeOrder
  .map((type) => ({
    type,
    count: characters.filter((character) => (character.data.type || 'unknown') === type).length,
  }))
  .filter((entry) => entry.count > 0);
---

<BaseLayout title={`${t('nav.characters')} | Wiki`} section="characters">
  <div slot="sidebar" class="space-y-3 text-sm text-[color:var(--ink-200)]">
    <div class="surface-panel-muted rounded-2xl p-4">
      <p class="font-semibold text-[color:var(--ink-50)]">
        {validatedLang === 'cn' ? '目录总数' : 'Directory Total'}
      </p>
      <div class="mt-2 font-display text-4xl text-[color:var(--ink-50)]">{characters.length}</div>
    </div>
    <div class="surface-panel-muted rounded-2xl p-4">
      <p class="font-semibold text-[color:var(--ink-50)]">
        {validatedLang === 'cn' ? '身份分布' : 'By Alignment'}
      </p>
      <div class="mt-3 flex flex-wrap gap-2">
        {counts.map((entry) => (
          <span class="rounded-full border border-[rgba(255,255,255,0.12)] px-3 py-1 text-xs uppercase tracking-widest text-[color:var(--ink-200)]">
            {entry.count} {typeLabels[entry.type]?.[validatedLang] || entry.type}
          </span>
        ))}
      </div>
    </div>
    <a href={`${base}/editions`} class="rail-link">
      <span>{validatedLang === 'cn' ? '去看剧本组合' : 'View script rosters'}</span>
      <span aria-hidden="true">-></span>
    </a>
  </div>

  <section class="surface-panel rounded-[30px] p-6 sm:p-8">
    <p class="uppercase tracking-[0.4em] text-xs text-[color:var(--ink-200)]">Grimoire Index</p>
    <h1 class="mt-3 font-display text-4xl text-[color:var(--ink-50)] sm:text-5xl">
      {t('nav.characters')}
    </h1>
    <p class="mt-3 max-w-3xl text-base text-[color:var(--ink-200)] sm:text-lg">
      {validatedLang === 'cn'
        ? '浏览和搜索血染钟楼的全部角色。'
        : 'Browse and search all Blood on the Clocktower characters.'}
    </p>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      {counts.slice(0, 4).map((entry) => (
        <div class="surface-panel-muted rounded-[24px] p-4">
          <div class="font-display text-3xl text-[color:var(--ink-50)]">{entry.count}</div>
          <div class="mt-2 text-sm text-[color:var(--ink-200)]">
            {typeLabels[entry.type]?.[validatedLang] || entry.type}
          </div>
        </div>
      ))}
    </div>
  </section>

  <CharacterList characters={characters} lang={validatedLang} />
</BaseLayout>
