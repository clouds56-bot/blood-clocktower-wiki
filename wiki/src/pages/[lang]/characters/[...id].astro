---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { defaultLang, useTranslations, getBasePath, getSupportedLangs, getAssetUrl } from '../../../i18n/utils';
import remindersData from '../../../../../data/config/reminders.json';

const supportedLangCodes = getSupportedLangs().map(({ code }) => code);

export async function getStaticPaths() {
  const characters = await getCollection('characters');
  return getSupportedLangs().flatMap(({ code }) =>
    characters.map((char) => ({
      params: { lang: code, id: char.id },
      props: { char },
    }))
  );
}

const { char } = Astro.props;
const data = char.data;
const { lang } = Astro.params;
const validatedLang = lang && supportedLangCodes.includes(lang) ? lang : defaultLang;
const { t } = useTranslations(validatedLang);

const characterId = data.id || char.id.split('/').pop();
const characterReminders = remindersData.reminders.filter(r => r.character_id === characterId);
const allCharacters = await getCollection('characters');
const characterMetaById = new Map(
  allCharacters.map((entry) => {
    const id = entry.data.id || entry.id.split('/').pop();
    return [
      id,
      {
        nameEn: entry.data.name?.en,
        nameCn: entry.data.name?.cn,
        routeId: entry.id,
      },
    ];
  })
);
const characterJinxRelations = [
  ...(data.jinxes || []),
].map((jinx: { id: string; reason?: string | Record<string, string> }) => {
  const target = characterMetaById.get(jinx.id);
  const nameCn = target?.nameCn;
  const nameEn = target?.nameEn;
  const name = validatedLang === 'cn' ? (nameCn || nameEn || jinx.id) : (nameEn || nameCn || jinx.id);
  const altName = validatedLang === 'cn' && nameEn ? nameEn : undefined;
  const reasonObj = typeof jinx.reason === 'object' && jinx.reason !== null ? jinx.reason : null;
  const reason = reasonObj
    ? (reasonObj[validatedLang] || reasonObj.en || Object.values(reasonObj)[0])
    : jinx.reason;
  return {
    ...jinx,
    name,
    altName,
    reason,
    routeId: target?.routeId,
  };
});
---

<BaseLayout title={`${data.name?.[validatedLang] || data.name?.en || data.id} | Wiki`}>
  <div class="mb-6">
    <a href={`${getBasePath(validatedLang)}/characters`} class="text-[color:var(--ink-200)] hover:text-[color:var(--accent-gold)] transition">{t('char.back')}</a>
  </div>

  <div class="surface-panel rounded-3xl p-6 sm:p-8">
    <header class="mb-8">
      <div class="flex flex-col lg:flex-row lg:items-center gap-6">
        <div class="flex justify-center lg:justify-start">
          <div class="token-ring w-40 h-40 sm:w-48 sm:h-48 rounded-full overflow-hidden bg-[color:var(--bg-700)] border border-[rgba(215,180,106,0.5)]">
            {
              (() => {
                const id = data.id || char.id.split('/').pop();
                const imgField = data.image ? data.image.replace(/^\/+/, '') : `assets/tokens/${id}.png`;
                const src = getAssetUrl(imgField);
                return <img src={src} alt={data.name?.[validatedLang] || data.id} class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'" />;
              })()
            }
          </div>
        </div>
        <div class="flex-1 min-w-0">
          <p class="uppercase tracking-[0.35em] text-xs text-[color:var(--ink-200)]">Character Dossier</p>
          <div class="mt-3">
            <h1 class="font-display text-4xl sm:text-5xl text-[color:var(--ink-50)] truncate">{data.name?.[validatedLang] || data.name?.en}</h1>
            {validatedLang === 'cn' && data.name?.en && <div class="text-lg text-[color:var(--ink-200)] mt-2">{data.name.en}</div>}
            {validatedLang === 'en' && data.name?.cn && <div class="text-lg text-[color:var(--ink-200)] mt-2">{data.name.cn}</div>}
          </div>
          <div class="flex flex-wrap gap-2 mt-4 text-xs uppercase tracking-widest">
            <span class="px-3 py-1 rounded-full border border-[rgba(215,180,106,0.4)] text-[color:var(--accent-gold)]">
              {data.type}
            </span>
            {data.editions && data.editions.map((edition: string) => (
              <span class="px-3 py-1 rounded-full border border-[rgba(255,255,255,0.15)] text-[color:var(--ink-200)]">
                {edition.replace('_', ' ')}
              </span>
            ))}
          </div>

          {data.flavor?.[validatedLang] && (
            <blockquote class="mt-5 italic text-[color:var(--ink-200)] border-l-4 border-[rgba(215,180,106,0.45)] pl-4 py-1">
              {validatedLang === 'cn' ? data.flavor?.cn : data.flavor?.en}
              {validatedLang === 'cn' && data.flavor?.en && (
                <div class="mt-2 text-[color:var(--ink-300)] text-sm normal-case">{data.flavor.en}</div>
              )}
              {validatedLang !== 'cn' && data.flavor?.cn ? null : null}
            </blockquote>
          )}

          {(characterReminders.length > 0 || characterJinxRelations.length > 0) && (
            <div class="mt-5 space-y-3">
              {characterReminders.length > 0 && (
                <div>
                  <p class="uppercase tracking-[0.28em] text-xs text-[color:var(--ink-200)] mb-2">{t('char.reminders')}</p>
                  <div class="flex flex-wrap gap-2">
                    {characterReminders.map((r) => {
                      const name = validatedLang === 'cn' ? (r.name?.cn || r.name?.en) : (r.name?.en || r.name?.cn);
                      const alt = validatedLang === 'cn' ? r.name?.en : undefined;
                      return (
                        <span class="px-3 py-1 rounded-full border border-[rgba(215,180,106,0.3)] text-[color:var(--ink-50)] text-xs uppercase tracking-wide">
                          {name}
                          {alt && <span class="ml-2 text-[color:var(--ink-300)] text-xs normal-case">{alt}</span>}
                        </span>
                      );
                    })}
                  </div>
                </div>
              )}

              {characterJinxRelations.length > 0 && (
                <div>
                  <p class="uppercase tracking-[0.28em] text-xs text-[color:var(--ink-200)] mb-2">{t('char.jinxes')}</p>
                  <div class="flex flex-wrap gap-2">
                    {characterJinxRelations.map((jinx) => {
                      const display = jinx.name;
                      const alt = jinx.altName;
                      const content = (
                        <>
                          <span>{display}</span>
                          {alt && validatedLang === 'cn' && <span class="ml-2 text-[color:var(--ink-300)] text-xs normal-case">{alt}</span>}
                        </>
                      );
                      return jinx.routeId ? (
                        <a
                          href={`${getBasePath(validatedLang)}/characters/${jinx.routeId}`}
                          class="px-3 py-1 rounded-full border border-[rgba(255,255,255,0.18)] text-[color:var(--ink-100)] text-xs uppercase tracking-wide hover:border-[rgba(215,180,106,0.5)] hover:text-[color:var(--accent-gold)] transition"
                        >
                          {content}
                        </a>
                      ) : (
                        <span class="px-3 py-1 rounded-full border border-[rgba(255,255,255,0.18)] text-[color:var(--ink-100)] text-xs uppercase tracking-wide">
                          {content}
                        </span>
                      );
                    })}
                  </div>
                </div>
              )}
            </div>
          )}
        </div>
      </div>
    </header>

    {data.ability?.[validatedLang] && (
      <section class="mb-10">
        <div class="rounded-2xl border border-[rgba(215,180,106,0.35)] bg-[color:var(--bg-800)] p-5 sm:p-6">
          <p class="uppercase tracking-[0.3em] text-xs text-[color:var(--ink-200)] mb-3">{t('char.ability')}</p>
          <p class="text-lg sm:text-xl text-[color:var(--ink-50)] leading-relaxed">{data.ability?.[validatedLang]}</p>
          {data.ability?.[validatedLang === 'en' ? 'cn' : 'en'] && (
            <p class="mt-3 text-[color:var(--ink-200)]">{data.ability?.[validatedLang === 'en' ? 'cn' : 'en']}</p>
          )}
        </div>
      </section>
    )}

    {characterReminders.length > 0 && (
      <section class="mb-8">
        <h2 class="font-display text-2xl mb-4 text-[color:var(--ink-50)]">{t('char.reminders')}</h2>
        <div class="space-y-3">
          {characterReminders.map((r) => {
            const name = validatedLang === 'cn' ? (r.name?.cn || r.name?.en) : (r.name?.en || r.name?.cn);
            const alt = validatedLang === 'cn' ? r.name?.en : undefined;
            return (
              <div class="bg-[color:var(--bg-800)] px-4 py-3 rounded-xl border border-[rgba(215,180,106,0.28)]">
                <div class="text-[color:var(--ink-50)] font-medium">{name}</div>
                {alt && <div class="text-[color:var(--ink-300)] text-sm mt-1 normal-case">{alt}</div>}
                <div class="text-xs text-[color:var(--ink-300)] mt-1">{r.id}</div>
              </div>
            );
          })}
        </div>
      </section>
    )}

    {(data.tips?.[validatedLang]?.length > 0 || data.examples?.[validatedLang]?.length > 0) && (
      <section class="mt-8 space-y-4">
        {data.tips?.[validatedLang] && data.tips?.[validatedLang].length > 0 && (
          <details class="surface-panel rounded-2xl p-5 sm:p-6 group">
            <summary class="cursor-pointer list-none flex items-center justify-between gap-4">
              <h2 class="font-display text-2xl text-[color:var(--ink-50)]">{t('char.tips')}</h2>
              <span class="text-xs uppercase tracking-[0.2em] text-[color:var(--ink-200)] group-open:text-[color:var(--accent-gold)] transition">
                {data.tips?.[validatedLang].length}
              </span>
            </summary>
            <ul class="space-y-4 mt-4 pt-4 border-t soft-divider">
              {data.tips?.[validatedLang].map((tip: string) => (
                <li class="flex gap-3 text-[color:var(--ink-200)]">
                  <span class="text-[color:var(--accent-gold)] mt-1">✦</span>
                  <span>{tip}</span>
                </li>
              ))}
            </ul>
          </details>
        )}

        {data.examples?.[validatedLang] && data.examples?.[validatedLang].length > 0 && (
          <details class="surface-panel rounded-2xl p-5 sm:p-6 group">
            <summary class="cursor-pointer list-none flex items-center justify-between gap-4">
              <h2 class="font-display text-2xl text-[color:var(--ink-50)]">{t('char.examples')}</h2>
              <span class="text-xs uppercase tracking-[0.2em] text-[color:var(--ink-200)] group-open:text-[color:var(--accent-gold)] transition">
                {data.examples?.[validatedLang].length}
              </span>
            </summary>
            <ul class="space-y-4 mt-4 pt-4 border-t soft-divider">
              {data.examples?.[validatedLang].map((ex: string) => (
                <li class="bg-[color:var(--bg-800)] p-4 rounded-xl border border-[rgba(215,180,106,0.2)] text-[color:var(--ink-200)] text-sm">
                  {ex}
                </li>
              ))}
            </ul>
          </details>
        )}
      </section>
    )}

    {data.how_to_run?.[validatedLang] && (
      <section class="mt-10 pt-6 border-t soft-divider">
        <h2 class="font-display text-2xl mb-4 text-[color:var(--ink-50)]">{t('char.how_to_run')}</h2>
        <p class="text-[color:var(--ink-200)]">{data.how_to_run?.[validatedLang]}</p>
      </section>
    )}

    {characterJinxRelations.length > 0 && (
      <section class="mt-10 pt-6 border-t soft-divider">
        <h2 class="font-display text-2xl mb-4 text-[color:var(--ink-50)]">{t('char.jinxes')}</h2>
        <div class="space-y-3">
          {characterJinxRelations.map((jinx) => (
            <div class="bg-[color:var(--bg-800)] p-4 rounded-xl border border-[rgba(215,180,106,0.22)]">
              <div class="text-[color:var(--ink-50)] font-medium">
                {jinx.routeId ? (
                  <a href={`${getBasePath(validatedLang)}/characters/${jinx.routeId}`} class="hover:text-[color:var(--accent-gold)] transition">
                    {jinx.name}
                  </a>
                ) : (
                  jinx.name
                )}
              </div>
              {jinx.reason && <p class="text-[color:var(--ink-200)] mt-2 text-sm">{jinx.reason}</p>}
            </div>
          ))}
        </div>
      </section>
    )}

    {data.source_url && (
      <div class="mt-10 text-sm text-[color:var(--ink-200)] text-right">
        <a href={data.source_url} target="_blank" rel="noopener noreferrer" class="hover:text-[color:var(--accent-gold)] underline">
          {t('char.view_official')}
        </a>
      </div>
    )}
  </div>
</BaseLayout>
