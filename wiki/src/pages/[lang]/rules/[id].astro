---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { defaultLang, useTranslations, getBasePath, getSupportedLangs } from '../../../i18n/utils';

const supportedLangCodes = getSupportedLangs().map(({ code }) => code);

export async function getStaticPaths() {
  const rules = await getCollection('rules');
  const genericRules = rules.filter(rule => rule.id !== 'glossary');
  return getSupportedLangs().flatMap(({ code }) =>
    genericRules.map((rule) => ({
      params: { lang: code, id: rule.id },
      props: { rule },
    }))
  );
}

const { rule } = Astro.props;
const data = rule.data;
const { lang } = Astro.params;
const validatedLang = lang && supportedLangCodes.includes(lang) ? lang : defaultLang;
const { t } = useTranslations(validatedLang);
---

<BaseLayout title={`${rule.id} | Wiki`}>
  <div class="mb-6">
    <a href={`${getBasePath(validatedLang)}/rules`} class="text-indigo-600 hover:underline">{t('rules.back')}</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8">
    <h1 class="text-4xl font-extrabold text-indigo-900 mb-6 capitalize">{rule.id.replace(/-/g, ' ')}</h1>

    <div class="prose max-w-none text-slate-700">
      <pre class="bg-slate-50 p-4 rounded-lg overflow-x-auto text-sm border border-slate-200">{JSON.stringify(data, null, 2)}</pre>
    </div>
  </div>
</BaseLayout>
