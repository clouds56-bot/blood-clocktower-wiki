---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { defaultLang, getSupportedLangs, useTranslations, getBasePath } from '../../../../i18n/utils';

const supportedLangCodes = getSupportedLangs().map(({ code }) => code);

export function getStaticPaths() {
  return getSupportedLangs().map(({ code }) => ({ params: { lang: code } }));
}

const rules = await getCollection('rules');
const { lang } = Astro.params;
const validatedLang = lang && supportedLangCodes.includes(lang) ? lang : defaultLang;
const { t } = useTranslations(validatedLang);
const base = getBasePath(validatedLang);

const glossary = rules.find(rule => rule.id === 'glossary');
const terms = Array.isArray(glossary?.data?.terms) ? glossary.data.terms : [];

const sortedTerms = [...terms].sort((a: any, b: any) => {
  const aName = (a?.name?.[validatedLang] || a?.name?.en || '') as string;
  const bName = (b?.name?.[validatedLang] || b?.name?.en || '') as string;

  if (validatedLang === 'cn') {
    return aName.localeCompare(bName, 'zh-CN-u-co-pinyin');
  }

  return aName.localeCompare(bName, 'en');
});
---

<BaseLayout title={`${t('glossary.title')} | Wiki`} section="glossary">
  <div slot="sidebar" class="space-y-3 text-sm text-[color:var(--ink-200)]">
    <div class="surface-panel-muted rounded-2xl p-4">
      <p class="font-semibold text-[color:var(--ink-50)]">
        {validatedLang === 'cn' ? '术语数量' : 'Term Count'}
      </p>
      <div class="mt-2 font-display text-4xl text-[color:var(--ink-50)]">{sortedTerms.length}</div>
    </div>
    <a href={`${base}/rules`} class="rail-link">
      <span>{validatedLang === 'cn' ? '返回规则中心' : 'Back to rules hub'}</span>
      <span aria-hidden="true">-></span>
    </a>
  </div>

  <section class="surface-panel rounded-[30px] p-6 sm:p-8">
    <p class="uppercase tracking-[0.4em] text-xs text-[color:var(--ink-200)]">Lexicon</p>
    <h1 class="mt-3 font-display text-4xl text-[color:var(--ink-50)] sm:text-5xl">
      {t('glossary.title')}
    </h1>
    <p class="mt-3 max-w-2xl text-base text-[color:var(--ink-200)] sm:text-lg">
      {validatedLang === 'cn'
        ? '按术语浏览血染钟楼常用规则词汇。'
        : 'Browse common Blood on the Clocktower terms and definitions.'}
    </p>
  </section>

  <div class="surface-panel rounded-2xl p-6 sm:p-8">
    <div class="space-y-6">
      {sortedTerms.map((term: any) => {
        const name = term?.name?.[validatedLang] || term?.name?.en || '';
        const description = term?.description?.[validatedLang] || term?.description?.en || '';
        const detailUrl = term?.detail_url?.[validatedLang] || term?.detail_url?.en || null;

        return (
          <article class="pb-6 border-b soft-divider last:border-b-0 last:pb-0">
            <h2 class="font-display text-2xl text-[color:var(--ink-50)] mb-2">{name}</h2>
            <p class="text-[color:var(--ink-200)] leading-relaxed">{description}</p>
            {detailUrl && (
              <a
                href={detailUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block mt-2 text-[color:var(--accent-gold)] hover:underline"
              >
                {t('glossary.learnMore')} ->
              </a>
            )}
          </article>
        );
      })}
    </div>
  </div>
</BaseLayout>
