---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { defaultLang, useTranslations, getSupportedLangs, getBasePath } from '../../i18n/utils';

const supportedLangCodes = getSupportedLangs().map(({ code }) => code);

export function getStaticPaths() {
  return getSupportedLangs().map(({ code }) => ({ params: { lang: code } }));
}

const { lang } = Astro.params;
const validatedLang = lang && supportedLangCodes.includes(lang) ? lang : defaultLang;

const { t } = useTranslations(validatedLang);
const editions = await getCollection('editions');
const characters = await getCollection('characters');
const rules = await getCollection('rules');
const base = getBasePath(validatedLang);

const getCharCount = (edition: any) => {
  const chars = edition.data.characters || {};
  const townsfolk = chars.townsfolk?.length || 0;
  const outsider = chars.outsider?.length || 0;
  const minion = chars.minion?.length || 0;
  const demon = chars.demon?.length || 0;
  return { townsfolk, outsider, minion, demon, total: townsfolk + outsider + minion + demon };
};
---

<BaseLayout title={`${t('home.title')} | Wiki`} section="home">
  <div slot="sidebar" class="space-y-3 text-sm text-[color:var(--ink-200)]">
    <div class="surface-panel-muted rounded-2xl p-4">
      <p class="font-semibold text-[color:var(--ink-50)]">
        {validatedLang === 'cn' ? '资料概览' : 'Library Snapshot'}
      </p>
      <div class="mt-3 grid grid-cols-2 gap-2 text-center">
        <div class="rounded-2xl bg-[rgba(255,255,255,0.03)] px-3 py-3">
          <div class="font-display text-2xl text-[color:var(--ink-50)]">{characters.length}</div>
          <div>{t('nav.characters')}</div>
        </div>
        <div class="rounded-2xl bg-[rgba(255,255,255,0.03)] px-3 py-3">
          <div class="font-display text-2xl text-[color:var(--ink-50)]">{editions.length}</div>
          <div>{t('nav.editions')}</div>
        </div>
      </div>
    </div>
    <div class="grid gap-2">
      <a href={`${base}/characters`} class="rail-link">
        <span>{validatedLang === 'cn' ? '按角色探索' : 'Explore by role'}</span>
        <span aria-hidden="true">-></span>
      </a>
      <a href={`${base}/editions`} class="rail-link">
        <span>{validatedLang === 'cn' ? '按剧本探索' : 'Explore by script'}</span>
        <span aria-hidden="true">-></span>
      </a>
      <a href={`${base}/rules/glossary`} class="rail-link">
        <span>{validatedLang === 'cn' ? '查看术语' : 'Open glossary'}</span>
        <span aria-hidden="true">-></span>
      </a>
    </div>
  </div>

  <section class="surface-panel rounded-[32px] p-6 sm:p-8 lg:p-10">
    <div class="grid gap-8 xl:grid-cols-[1.3fr_0.9fr] xl:items-start">
      <div>
        <p class="uppercase tracking-[0.4em] text-xs text-[color:var(--ink-200)]">
          {validatedLang === 'cn' ? '钟楼地图' : 'Clocktower Atlas'}
        </p>
        <h1 class="mt-4 font-display text-5xl leading-tight text-[color:var(--ink-50)] sm:text-6xl">
          {t('home.title')}
        </h1>
        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-[color:var(--ink-200)] sm:text-xl">
          {t('home.subtitle')}
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href={`${base}/characters`} class="rounded-full bg-[color:var(--accent-gold)] px-8 py-3 font-semibold text-[#1a141f] transition hover:bg-[#e5c67a]">
            {t('home.btn.characters')}
          </a>
          <a href={`${base}/editions`} class="rounded-full border border-[rgba(215,180,106,0.5)] px-8 py-3 font-semibold text-[color:var(--ink-50)] transition hover:bg-[rgba(215,180,106,0.1)]">
            {t('nav.editions')}
          </a>
          <a href={`${base}/rules`} class="rounded-full border border-[rgba(90,162,255,0.45)] px-8 py-3 font-semibold text-[color:var(--ink-50)] transition hover:bg-[rgba(90,162,255,0.1)]">
            {t('home.btn.rules')}
          </a>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-3 xl:grid-cols-1">
        <div class="surface-panel-muted rounded-[26px] p-5">
          <p class="uppercase tracking-[0.28em] text-xs text-[color:var(--ink-200)]">
            {validatedLang === 'cn' ? '角色库' : 'Character Vault'}
          </p>
          <div class="mt-3 font-display text-4xl text-[color:var(--ink-50)]">{characters.length}</div>
          <p class="mt-2 text-sm leading-relaxed text-[color:var(--ink-200)]">
            {validatedLang === 'cn' ? '从镇民到恶魔，全部角色集中在一个目录里。' : 'Every role, from Townsfolk to Demons, in one searchable directory.'}
          </p>
        </div>
        <div class="surface-panel-muted rounded-[26px] p-5">
          <p class="uppercase tracking-[0.28em] text-xs text-[color:var(--ink-200)]">
            {validatedLang === 'cn' ? '剧本档案' : 'Script Archive'}
          </p>
          <div class="mt-3 font-display text-4xl text-[color:var(--ink-50)]">{editions.length}</div>
          <p class="mt-2 text-sm leading-relaxed text-[color:var(--ink-200)]">
            {validatedLang === 'cn' ? '先从剧本入手，再深入对应角色和夜晚顺序。' : 'Start with a script, then branch into its role list and night order.'}
          </p>
        </div>
        <div class="surface-panel-muted rounded-[26px] p-5">
          <p class="uppercase tracking-[0.28em] text-xs text-[color:var(--ink-200)]">
            {validatedLang === 'cn' ? '规则工具' : 'Rules Desk'}
          </p>
          <div class="mt-3 font-display text-4xl text-[color:var(--ink-50)]">{rules.length}</div>
          <p class="mt-2 text-sm leading-relaxed text-[color:var(--ink-200)]">
            {validatedLang === 'cn' ? '术语、设置与关键规则被放在更近的入口。' : 'Glossary, setup, and reference material stay close at hand.'}
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-2 2xl:grid-cols-4">
    <a href={`${base}/characters`} class="surface-panel rounded-[28px] p-6 transition hover:-translate-y-1">
      <p class="uppercase tracking-[0.3em] text-xs text-[color:var(--ink-200)]">01</p>
      <h2 class="mt-3 font-display text-2xl text-[color:var(--ink-50)]">{t('nav.characters')}</h2>
      <p class="mt-3 text-sm leading-relaxed text-[color:var(--ink-200)]">
        {validatedLang === 'cn' ? '筛选角色身份，快速跳到单卡页。' : 'Filter roles by type, then drill into individual dossiers.'}
      </p>
    </a>
    <a href={`${base}/editions`} class="surface-panel rounded-[28px] p-6 transition hover:-translate-y-1">
      <p class="uppercase tracking-[0.3em] text-xs text-[color:var(--ink-200)]">02</p>
      <h2 class="mt-3 font-display text-2xl text-[color:var(--ink-50)]">{t('nav.editions')}</h2>
      <p class="mt-3 text-sm leading-relaxed text-[color:var(--ink-200)]">
        {validatedLang === 'cn' ? '把每个剧本的角色构成与夜晚顺序放在一起查看。' : 'See each script alongside its role mix and night order.'}
      </p>
    </a>
    <a href={`${base}/rules`} class="surface-panel rounded-[28px] p-6 transition hover:-translate-y-1">
      <p class="uppercase tracking-[0.3em] text-xs text-[color:var(--ink-200)]">03</p>
      <h2 class="mt-3 font-display text-2xl text-[color:var(--ink-50)]">{t('nav.rules')}</h2>
      <p class="mt-3 text-sm leading-relaxed text-[color:var(--ink-200)]">
        {validatedLang === 'cn' ? '查阅开局配置、核心规则与主持辅助信息。' : 'Reach setup charts, core reference pages, and storyteller support.'}
      </p>
    </a>
    <a href={`${base}/rules/glossary`} class="surface-panel rounded-[28px] p-6 transition hover:-translate-y-1">
      <p class="uppercase tracking-[0.3em] text-xs text-[color:var(--ink-200)]">04</p>
      <h2 class="mt-3 font-display text-2xl text-[color:var(--ink-50)]">{t('nav.glossary')}</h2>
      <p class="mt-3 text-sm leading-relaxed text-[color:var(--ink-200)]">
        {validatedLang === 'cn' ? '把常见术语集中整理，适合边玩边查。' : 'A concentrated term list for quick checks mid-game.'}
      </p>
    </a>
  </section>

  <section class="grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
    <div class="surface-panel rounded-[30px] p-6 sm:p-8">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="uppercase tracking-[0.35em] text-xs text-[color:var(--ink-200)]">
            {validatedLang === 'cn' ? '最近剧本' : 'Recent Editions'}
          </p>
          <h2 class="mt-3 font-display text-3xl text-[color:var(--ink-50)]">
            {validatedLang === 'cn' ? '从剧本开始浏览' : 'Start from the scripts'}
          </h2>
        </div>
        <a href={`${base}/editions`} class="text-sm text-[color:var(--accent-gold)] hover:underline">
          {validatedLang === 'cn' ? '查看全部 ->' : 'View all ->'}
        </a>
      </div>
      <div class="mt-6 grid gap-4 lg:grid-cols-2">
        {editions.slice(0, 4).map((edition) => {
          const name = edition.data.name?.[validatedLang] || edition.data.name?.en || edition.id;
          const description = edition.data.description?.[validatedLang] || edition.data.description?.en || '';
          const counts = getCharCount(edition);

          return (
            <a
              href={`${base}/editions/${edition.id}`}
              class="surface-panel-muted block rounded-[24px] p-5 transition hover:-translate-y-1"
            >
              <h3 class="font-display text-2xl text-[color:var(--ink-50)]">{name}</h3>
              <p class="mt-3 line-clamp-4 text-sm leading-relaxed text-[color:var(--ink-200)]">
                {description}
              </p>
              <div class="mt-4 flex flex-wrap gap-2 text-xs uppercase tracking-widest">
                <span class="rounded-full border border-[rgba(90,162,255,0.4)] px-3 py-1 text-[color:var(--accent-blue)]">
                  {counts.total} {t('nav.characters')}
                </span>
                <span class="rounded-full border border-[rgba(255,255,255,0.14)] px-3 py-1 text-[color:var(--ink-200)]">
                  {counts.demon} {validatedLang === 'cn' ? '恶魔' : 'Demons'}
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </div>

    <div class="surface-panel rounded-[30px] p-6 sm:p-8">
      <p class="uppercase tracking-[0.35em] text-xs text-[color:var(--ink-200)]">
        {validatedLang === 'cn' ? '浏览路线' : 'Browse Routes'}
      </p>
      <div class="mt-5 space-y-4">
        <div class="surface-panel-muted rounded-[24px] p-5">
          <h3 class="font-display text-2xl text-[color:var(--ink-50)]">
            {validatedLang === 'cn' ? '主持人' : 'Storyteller'}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-[color:var(--ink-200)]">
            {validatedLang === 'cn' ? '先看剧本页，再配合规则与夜晚顺序快速准备一局。' : 'Open an edition first, then pair it with setup and night-order references.'}
          </p>
        </div>
        <div class="surface-panel-muted rounded-[24px] p-5">
          <h3 class="font-display text-2xl text-[color:var(--ink-50)]">
            {validatedLang === 'cn' ? '玩家' : 'Players'}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-[color:var(--ink-200)]">
            {validatedLang === 'cn' ? '从角色目录开始，再回到术语和规则确认关键细节。' : 'Start in the character directory, then verify wording in glossary and rules.'}
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
