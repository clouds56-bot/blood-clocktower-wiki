---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const rules = await getCollection('rules');
---

<BaseLayout title="Rules | Blood on the Clocktower Wiki">
  <h1 class="text-4xl font-bold mb-6 text-indigo-900">Rules & Setup</h1>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {rules.map(rule => (
      <a href={`/rules/${rule.id}`} class="block p-6 bg-white rounded-lg shadow-sm border border-slate-200 hover:border-indigo-400 hover:shadow-md transition">
        <h2 class="text-2xl font-bold mb-2 capitalize text-indigo-800">{rule.id.replace(/-/g, ' ')}</h2>
        <p class="text-slate-600">View detailed rules for {rule.id.replace(/-/g, ' ')}.</p>
      </a>
    ))}
  </div>
</BaseLayout>
