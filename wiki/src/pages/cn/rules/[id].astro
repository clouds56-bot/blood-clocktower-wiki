---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getBasePath } from '../../../i18n/utils';

export async function getStaticPaths() {
  const rules = await getCollection('rules');
  return rules.map(rule => ({
    params: { id: rule.id },
    props: { rule }
  }));
}

const { rule } = Astro.props;
const data = rule.data;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={`${rule.id} | Wiki`}>
  <div class="mb-6">
    <a href={`${getBasePath('cn')}/rules`} class="text-indigo-600 hover:underline">{t('rules.back')}</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8">
    <h1 class="text-4xl font-extrabold text-indigo-900 mb-6 capitalize">{rule.id.replace(/-/g, ' ')}</h1>
    
    <div class="prose max-w-none text-slate-700">
      <pre class="bg-slate-50 p-4 rounded-lg overflow-x-auto text-sm border border-slate-200">{JSON.stringify(data, null, 2)}</pre>
    </div>
  </div>
</BaseLayout>
