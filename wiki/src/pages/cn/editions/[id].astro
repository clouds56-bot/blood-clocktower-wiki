---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, getLangFromUrl, getBasePath } from '../../../i18n/utils';

export async function getStaticPaths() {
  const editions = await getCollection('editions');
  return editions.map(edition => ({
    params: { id: edition.id },
    props: { edition }
  }));
}

const { edition } = Astro.props;
const data = edition.data;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = getBasePath(lang);

const characters = await getCollection('characters');
const characterMap = new Map(characters.map(c => [c.id, c]));

const typeLabels: Record<string, any> = {
  'townsfolk': { en: 'Townsfolk', cn: '镇民' },
  'outsiders': { en: 'Outsiders', cn: '外来者' },
  'minions': { en: 'Minions', cn: '爪牙' },
  'demons': { en: 'Demons', cn: '恶魔' }
};

const getTypeLabel = (type: string) => typeLabels[type]?.[lang] || type;
---

<BaseLayout title={`${data.name?.[lang] || data.name?.en || edition.id} | Wiki`}>
  <div class="mb-6">
    <a href={`${base}/editions`} class="text-[color:var(--ink-200)] hover:text-[color:var(--accent-gold)] transition">{t('editions.back')}</a>
  </div>

  <div class="surface-panel rounded-3xl p-6 sm:p-8">
    <header class="mb-8">
      <p class="uppercase tracking-[0.35em] text-xs text-[color:var(--ink-200)]">剧本</p>
      <h1 class="font-display text-4xl sm:text-5xl mt-3 text-[color:var(--ink-50)]">
        {data.name?.[lang] || data.name?.en}
      </h1>
      {lang === 'cn' && data.name?.en && <div class="text-lg text-[color:var(--ink-200)] mt-2">{data.name.en}</div>}
      {lang === 'en' && data.name?.cn && <div class="text-lg text-[color:var(--ink-200)] mt-2">{data.name.cn}</div>}
    </header>

    {data.description?.[lang] && (
      <section class="mb-10">
        <div class="rounded-2xl border border-[rgba(215,180,106,0.35)] bg-[color:var(--bg-800)] p-5 sm:p-6">
          <p class="text-base sm:text-lg text-[color:var(--ink-50)] leading-relaxed">{data.description?.[lang]}</p>
          {data.description?.[lang === 'en' ? 'cn' : 'en'] && (
            <p class="mt-3 text-[color:var(--ink-200)]">{data.description?.[lang === 'en' ? 'cn' : 'en']}</p>
          )}
        </div>
      </section>
    )}

    <section class="mb-10">
      <h2 class="font-display text-2xl mb-6 text-[color:var(--ink-50)] border-b soft-divider pb-2">{t('editions.characters')}</h2>
      
      {['townsfolk', 'outsiders', 'minions', 'demons'].map(type => {
        const chars = data.characters?.[type] || [];
        if (chars.length === 0) return null;
        
        return (
          <div class="mb-6">
            <h3 class="font-display text-xl mb-3 text-[color:var(--ink-50)]">{getTypeLabel(type)}</h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
              {chars.map((charId: string) => {
                const char = characterMap.get(charId);
                const charName = char?.data.name?.[lang] || char?.data.name?.en || charId;
                const charSubtitle = lang === 'en' ? char?.data.name?.cn : char?.data.name?.en;
                const isGood = ['townsfolk', 'outsiders'].includes(type);
                
                return (
                  <a
                    href={`${base}/characters/${charId}`}
                    class="block surface-panel rounded-xl p-3 hover:-translate-y-1 transition-all duration-300 border border-[rgba(215,180,106,0.2)]"
                  >
                    <div class="font-display text-sm sm:text-base text-[color:var(--ink-50)]">{charName}</div>
                    {charSubtitle && <div class="text-xs text-[color:var(--ink-200)] mt-1">{charSubtitle}</div>}
                  </a>
                );
              })}
            </div>
          </div>
        );
      })}
    </section>

    {data.night_order && (data.night_order.first_night || data.night_order.other_nights) && (
      <section class="mb-10">
        <h2 class="font-display text-2xl mb-6 text-[color:var(--ink-50)] border-b soft-divider pb-2">夜晚顺序</h2>
        
        {data.night_order.first_night && data.night_order.first_night.length > 0 && (
          <div class="mb-6">
            <h3 class="font-display text-xl mb-4 text-[color:var(--ink-50)]">{t('editions.first_night')}</h3>
            <div class="space-y-2">
              {data.night_order.first_night.map((item: any) => {
                const char = characterMap.get(item.character);
                const charName = char?.data.name?.[lang] || char?.data.name?.en || item.character;
                const typeLabel = typeLabels[item.type]?.[lang] || item.type;
                const isGood = ['townsfolk', 'outsiders'].includes(item.type);
                
                return (
                  <div class="flex items-center gap-3 surface-panel rounded-xl p-3 border border-[rgba(215,180,106,0.2)]">
                    <div class="flex-shrink-0 w-8 h-8 rounded-full bg-[color:var(--bg-700)] flex items-center justify-center text-sm font-semibold text-[color:var(--accent-gold)] border border-[rgba(215,180,106,0.4)]">
                      {item.number}
                    </div>
                    <div class="flex-1 min-w-0">
                      <a href={`${base}/characters/${item.character}`} class="text-[color:var(--ink-50)] hover:text-[color:var(--accent-gold)] transition font-medium">
                        {charName}
                      </a>
                    </div>
                    <span class={`text-xs uppercase tracking-wider px-2 py-1 rounded-full border ${isGood ? 'border-[rgba(90,162,255,0.4)] text-[color:var(--accent-blue)]' : 'border-[rgba(255,90,90,0.4)] text-[color:var(--accent-red)]'}`}>
                      {typeLabel}
                    </span>
                  </div>
                );
              })}
            </div>
          </div>
        )}
        
        {data.night_order.other_nights && data.night_order.other_nights.length > 0 && (
          <div>
            <h3 class="font-display text-xl mb-4 text-[color:var(--ink-50)]">{t('editions.other_nights')}</h3>
            <div class="space-y-2">
              {data.night_order.other_nights.map((item: any) => {
                const char = characterMap.get(item.character);
                const charName = char?.data.name?.[lang] || char?.data.name?.en || item.character;
                const typeLabel = typeLabels[item.type]?.[lang] || item.type;
                const isGood = ['townsfolk', 'outsiders'].includes(item.type);
                
                return (
                  <div class="flex items-center gap-3 surface-panel rounded-xl p-3 border border-[rgba(215,180,106,0.2)]">
                    <div class="flex-shrink-0 w-8 h-8 rounded-full bg-[color:var(--bg-700)] flex items-center justify-center text-sm font-semibold text-[color:var(--accent-gold)] border border-[rgba(215,180,106,0.4)]">
                      {item.number}
                    </div>
                    <div class="flex-1 min-w-0">
                      <a href={`${base}/characters/${item.character}`} class="text-[color:var(--ink-50)] hover:text-[color:var(--accent-gold)] transition font-medium">
                        {charName}
                      </a>
                    </div>
                    <span class={`text-xs uppercase tracking-wider px-2 py-1 rounded-full border ${isGood ? 'border-[rgba(90,162,255,0.4)] text-[color:var(--accent-blue)]' : 'border-[rgba(255,90,90,0.4)] text-[color:var(--accent-red)]'}`}>
                      {typeLabel}
                    </span>
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </section>
    )}
    
    {data.source_url && data.source_url[lang] && (
      <div class="mt-10 text-sm text-[color:var(--ink-200)] text-right">
        <a href={data.source_url[lang]} target="_blank" rel="noopener noreferrer" class="hover:text-[color:var(--accent-gold)] underline">
          {t('editions.view_official')}
        </a>
      </div>
    )}
  </div>
</BaseLayout>
