---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home | Blood on the Clocktower Wiki">
  <div class="flex flex-col items-center justify-center text-center mt-12 gap-6">
    <h1 class="text-5xl font-extrabold text-indigo-950 mb-4">
      Blood on the Clocktower
    </h1>
    <p class="text-xl text-slate-700 max-w-2xl">
      Welcome to the open-source, interactive wiki for the greatest social deduction game.
      Browse characters, rule sets, and explore mechanics.
    </p>
    
    <div class="flex gap-4 mt-8">
      <a href="/characters" class="px-6 py-3 bg-indigo-600 text-white rounded-lg shadow font-medium hover:bg-indigo-700 transition">
        View Characters
      </a>
      <a href="/rules" class="px-6 py-3 bg-white text-indigo-700 border border-indigo-200 rounded-lg shadow-sm font-medium hover:bg-indigo-50 transition">
        Browse Rules
      </a>
    </div>
  </div>
</BaseLayout>
