---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = `/${lang}`;
---

<BaseLayout title={`${t('home.title')} | Wiki`}>
  <div class="flex flex-col items-center justify-center text-center mt-12 gap-6">
    <h1 class="text-5xl font-extrabold text-indigo-950 mb-4">
      {t('home.title')}
    </h1>
    <p class="text-xl text-slate-700 max-w-2xl">
      {t('home.subtitle')}
    </p>

    <div class="flex gap-4 mt-8">
      <a href={`${base}/characters`} class="px-6 py-3 bg-indigo-600 text-white rounded-lg shadow font-medium hover:bg-indigo-700 transition">
        {t('home.btn.characters')}
      </a>
      <a href={`${base}/rules`} class="px-6 py-3 bg-white text-indigo-700 border border-indigo-200 rounded-lg shadow-sm font-medium hover:bg-indigo-50 transition">
        {t('home.btn.rules')}
      </a>
    </div>
  </div>
</BaseLayout>
