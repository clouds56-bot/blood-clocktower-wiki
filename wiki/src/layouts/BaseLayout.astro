---
import 'uno.css';
import { getLangFromUrl, useTranslations, getBasePath, stripLangFromPath, getSupportedLangs } from '../i18n/utils';
import LanguagePicker from '../components/LanguagePicker.astro';

interface Props {
  title?: string;
}

const { title = "Blood on the Clocktower — Wiki" } = Astro.props;
const langCode = getLangFromUrl(Astro.url);
const { t, lang } = useTranslations(langCode);
const base = getBasePath(langCode);
const pathBase = stripLangFromPath(Astro.url.pathname);
const canonicalUrl = `${Astro.url.origin}${base}${pathBase === '/' ? '' : pathBase}`;
const supportedLangs = getSupportedLangs();
---

<!doctype html>
<html lang={lang.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    {supportedLangs.map((langConfig) => (
      <link
        rel="alternate"
        hrefLang={langConfig.code}
        href={`${Astro.url.origin}${getBasePath(langConfig.code)}${pathBase === '/' ? '' : pathBase}`}
      />
    ))}
    <meta property="og:locale" content={lang.ogLocale} />
    {supportedLangs
      .filter((langConfig) => langConfig.code !== langCode)
      .map((langConfig) => (
        <meta
          property="og:locale:alternate"
          content={langConfig.ogLocale}
        />
      ))}
  </head>
  <body class="min-h-screen text-slate-100 font-sans">
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700;800&family=Source+Sans+3:wght@400;500;600;700&display=swap');

      :root {
        --bg-900: #0e0b12;
        --bg-800: #16121f;
        --bg-700: #221b2e;
        --ink-50: #f5f2eb;
        --ink-200: #d6d0c7;
        --accent-gold: #d7b46a;
        --accent-blue: #5aa2ff;
        --accent-red: #ff5a5a;
        --shadow-soft: 0 20px 60px rgba(0, 0, 0, 0.35);
      }

      body {
        font-family: 'Source Sans 3', ui-sans-serif, system-ui, -apple-system, sans-serif;
        background-color: var(--bg-900);
        background-image:
          radial-gradient(1200px 600px at 20% -10%, rgba(90, 162, 255, 0.08), transparent 60%),
          radial-gradient(900px 500px at 90% 10%, rgba(255, 90, 90, 0.08), transparent 55%),
          linear-gradient(120deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0));
        color: var(--ink-50);
      }

      .font-display {
        font-family: 'Cinzel', ui-serif, Georgia, serif;
        letter-spacing: 0.02em;
      }

      .surface-panel {
        background: linear-gradient(180deg, rgba(34, 27, 46, 0.96), rgba(20, 16, 28, 0.96));
        border: 1px solid rgba(215, 180, 106, 0.2);
        box-shadow: var(--shadow-soft);
      }

      .soft-divider {
        border-color: rgba(215, 180, 106, 0.2);
      }

      .token-ring {
        box-shadow: 0 0 0 2px rgba(215, 180, 106, 0.3), 0 10px 30px rgba(0, 0, 0, 0.35);
      }
    </style>

    <header class="sticky top-0 z-20 backdrop-blur-md bg-[#0f0c16]/85 border-b border-[rgba(215,180,106,0.25)]">
      <div class="max-w-6xl mx-auto flex flex-wrap items-center justify-between px-4 py-3 gap-4">
        <div class="flex items-center gap-4">
          <a href={`${base}/`} class="font-display text-xl sm:text-2xl text-[color:var(--ink-50)] hover:text-[color:var(--accent-gold)] transition">
            BotC Wiki
          </a>
          <LanguagePicker />
        </div>
        <nav class="flex gap-4 text-sm sm:text-base">
          <a href={`${base}/characters`} class="text-[color:var(--ink-200)] hover:text-[color:var(--accent-gold)] transition">{t('nav.characters')}</a>
          <a href={`${base}/editions`} class="text-[color:var(--ink-200)] hover:text-[color:var(--accent-gold)] transition">{t('nav.editions')}</a>
          <a href={`${base}/rules`} class="text-[color:var(--ink-200)] hover:text-[color:var(--accent-gold)] transition">{t('nav.rules')}</a>
        </nav>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8 min-h-[calc(100vh-160px)]">
      <slot />
    </main>

    <footer class="border-t border-[rgba(215,180,106,0.2)] text-[color:var(--ink-200)] text-center p-4 text-sm mt-8">
      <div class="max-w-6xl mx-auto">
        {t('footer.text')}
      </div>
    </footer>
  </body>
</html>
