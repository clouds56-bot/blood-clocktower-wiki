---
import 'uno.css';
import { getLangFromUrl, useTranslations, getBasePath, stripLangFromPath, getSupportedLangs, stripBase } from '../i18n/utils';
import LanguagePicker from '../components/LanguagePicker.astro';

interface Props {
  title?: string;
  section?: 'home' | 'characters' | 'editions' | 'rules' | 'glossary';
}

type SectionKey = NonNullable<Props['section']>;

const { title = 'Blood on the Clocktower - Wiki', section } = Astro.props;
const langCode = getLangFromUrl(Astro.url);
const { t, lang } = useTranslations(langCode);
const base = getBasePath(langCode);
const pathBase = stripLangFromPath(Astro.url.pathname);
const canonicalUrl = `${Astro.url.origin}${base}${pathBase === '/' ? '' : pathBase}`;
const supportedLangs = getSupportedLangs();
const hasSidebar = Astro.slots.has('sidebar');
const currentPath = stripBase(Astro.url.pathname).replace(/\/$/, '') || '/';

const labels: Record<SectionKey, string> = {
  home: langCode === 'cn' ? '总览' : 'Overview',
  characters: t('nav.characters'),
  editions: t('nav.editions'),
  rules: t('nav.rules'),
  glossary: t('nav.glossary'),
};

const navItems: Array<{ key: SectionKey; label: string; href: string; exact: boolean }> = [
  { key: 'home', label: labels.home, href: `${base}/`, exact: true },
  { key: 'characters', label: labels.characters, href: `${base}/characters`, exact: false },
  { key: 'editions', label: labels.editions, href: `${base}/editions`, exact: false },
  { key: 'rules', label: labels.rules, href: `${base}/rules`, exact: false },
  { key: 'glossary', label: labels.glossary, href: `${base}/rules/glossary`, exact: false },
];

const isActive = (href: string, exact: boolean) => {
  const normalizedHref = href.replace(/\/$/, '') || '/';
  if (exact) {
    return currentPath === normalizedHref;
  }

  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
};

const currentSection: SectionKey = section || navItems.find((item) => isActive(item.href, item.exact))?.key || 'home';
---

<!doctype html>
<html lang={lang.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    {supportedLangs.map((langConfig) => (
      <link
        rel="alternate"
        hrefLang={langConfig.code}
        href={`${Astro.url.origin}${getBasePath(langConfig.code)}${pathBase === '/' ? '' : pathBase}`}
      />
    ))}
    <meta property="og:locale" content={lang.ogLocale} />
    {supportedLangs
      .filter((langConfig) => langConfig.code !== langCode)
      .map((langConfig) => (
        <meta
          property="og:locale:alternate"
          content={langConfig.ogLocale}
        />
      ))}
  </head>
  <body class="min-h-screen text-slate-100 font-sans">
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700;800&family=Source+Sans+3:wght@400;500;600;700&display=swap');

      :root {
        --bg-900: #0e0b12;
        --bg-800: #16121f;
        --bg-700: #221b2e;
        --bg-650: #2d233d;
        --ink-50: #f5f2eb;
        --ink-100: #e7e1d7;
        --ink-200: #d6d0c7;
        --ink-300: #b7afa2;
        --accent-gold: #d7b46a;
        --accent-blue: #5aa2ff;
        --accent-red: #ff5a5a;
        --shadow-soft: 0 20px 60px rgba(0, 0, 0, 0.35);
      }

      body {
        font-family: 'Source Sans 3', ui-sans-serif, system-ui, -apple-system, sans-serif;
        background-color: var(--bg-900);
        background-image:
          radial-gradient(1200px 600px at 20% -10%, rgba(90, 162, 255, 0.08), transparent 60%),
          radial-gradient(900px 500px at 90% 10%, rgba(255, 90, 90, 0.08), transparent 55%),
          linear-gradient(120deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0));
        color: var(--ink-50);
      }

      .font-display {
        font-family: 'Cinzel', ui-serif, Georgia, serif;
        letter-spacing: 0.02em;
      }

      .surface-panel {
        background: linear-gradient(180deg, rgba(34, 27, 46, 0.96), rgba(20, 16, 28, 0.96));
        border: 1px solid rgba(215, 180, 106, 0.2);
        box-shadow: var(--shadow-soft);
      }

      .surface-panel-muted {
        background: linear-gradient(180deg, rgba(45, 35, 61, 0.72), rgba(19, 15, 28, 0.72));
        border: 1px solid rgba(255, 255, 255, 0.08);
      }

      .soft-divider {
        border-color: rgba(215, 180, 106, 0.2);
      }

      .token-ring {
        box-shadow: 0 0 0 2px rgba(215, 180, 106, 0.3), 0 10px 30px rgba(0, 0, 0, 0.35);
      }

      .rail-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        border-radius: 1rem;
        padding: 0.9rem 1rem;
        color: var(--ink-200);
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: 180ms ease;
      }

      .rail-link:hover {
        color: var(--ink-50);
        border-color: rgba(215, 180, 106, 0.28);
        transform: translateX(4px);
      }

      .rail-link.active {
        color: var(--ink-50);
        background: linear-gradient(135deg, rgba(215, 180, 106, 0.18), rgba(90, 162, 255, 0.08));
        border-color: rgba(215, 180, 106, 0.42);
      }

      .tag-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border-radius: 999px;
        border: 1px solid rgba(215, 180, 106, 0.28);
        padding: 0.35rem 0.7rem;
        font-size: 0.75rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent-gold);
      }
    </style>

    <div class="mx-auto max-w-[1500px] px-4 py-4 sm:px-6 sm:py-6">
      <div class="lg:grid lg:grid-cols-[300px_minmax(0,1fr)] lg:gap-6">
        <aside class="space-y-4 lg:sticky lg:top-4 self-start">
          <section class="surface-panel rounded-[28px] p-5 sm:p-6">
            <p class="uppercase tracking-[0.35em] text-xs text-[color:var(--ink-200)]">
              Blood on the Clocktower
            </p>
            <a href={`${base}/`} class="mt-3 inline-block font-display text-3xl leading-none text-[color:var(--ink-50)] hover:text-[color:var(--accent-gold)] transition">
              Wiki Atlas
            </a>
            <p class="mt-4 text-sm leading-relaxed text-[color:var(--ink-200)]">
              {langCode === 'cn'
                ? '保留原有气质，同时把资料入口、导航和侧栏重新编排得更清晰。'
                : 'The same candlelit theme, reorganized into a clearer atlas of characters, editions, and rules.'}
            </p>
            <div class="mt-5 flex flex-wrap gap-2">
              <LanguagePicker />
            </div>
            <nav class="mt-6 grid gap-2">
              {navItems.map((item) => (
                <a href={item.href} class={`rail-link ${isActive(item.href, item.exact) ? 'active' : ''}`}>
                  <span>{item.label}</span>
                  <span aria-hidden="true">-></span>
                </a>
              ))}
            </nav>
          </section>

          <section class="surface-panel rounded-[28px] p-5 sm:p-6">
            <div class="flex items-center justify-between gap-3">
              <p class="uppercase tracking-[0.32em] text-xs text-[color:var(--ink-200)]">
                {langCode === 'cn' ? '当前区域' : 'Current Area'}
              </p>
              <span class="tag-chip">{labels[currentSection]}</span>
            </div>

            {hasSidebar ? (
              <div class="mt-4">
                <slot name="sidebar" />
              </div>
            ) : (
              <div class="mt-4 space-y-3 text-sm text-[color:var(--ink-200)]">
                <div class="surface-panel-muted rounded-2xl p-4">
                  <p class="font-semibold text-[color:var(--ink-50)]">
                    {langCode === 'cn' ? '快速开始' : 'Quick Start'}
                  </p>
                  <p class="mt-2 leading-relaxed">
                    {langCode === 'cn'
                      ? '先看剧本，再跳到角色和规则页，就能很快建立全局印象。'
                      : 'Start with an edition, then jump into characters and rules to build context quickly.'}
                  </p>
                </div>
                <div class="grid gap-2">
                  <a href={`${base}/editions`} class="rail-link">
                    <span>{t('nav.editions')}</span>
                    <span aria-hidden="true">-></span>
                  </a>
                  <a href={`${base}/characters`} class="rail-link">
                    <span>{t('nav.characters')}</span>
                    <span aria-hidden="true">-></span>
                  </a>
                </div>
              </div>
            )}
          </section>
        </aside>

        <div class="mt-6 min-w-0 lg:mt-0">
          <main class="space-y-6 min-h-[calc(100vh-140px)]">
            <slot />
          </main>

          <footer class="mt-6 border-t border-[rgba(215,180,106,0.2)] px-2 pt-4 text-sm text-[color:var(--ink-200)]">
            {t('footer.text')}
          </footer>
        </div>
      </div>
    </div>
  </body>
</html>
