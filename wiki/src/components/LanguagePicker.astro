---
import { languages, getLangFromUrl, getBasePath, stripLangFromPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const routeBase = stripLangFromPath(Astro.url.pathname);
---

<div class="flex gap-2 text-sm font-medium items-center ml-4 border-l border-indigo-700 pl-4">
  {Object.entries(languages).map(([l, label]) => {
    const isCurrent = l === lang;
    const href = `${getBasePath(l as keyof typeof languages)}${routeBase === '/' ? '' : routeBase}`;
    return (
      <a 
        href={href} 
        class={`transition ${isCurrent ? 'text-white underline' : 'text-indigo-300 hover:text-indigo-100'}`}
      >
        {label}
      </a>
    );
  })}
</div>
