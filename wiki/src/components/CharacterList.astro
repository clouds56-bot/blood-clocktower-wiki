---
import { useTranslations, getBasePath, getAssetUrl } from '../i18n/utils';

export interface Props {
  characters: any[];
  lang: 'en' | 'cn';
}

const { characters, lang } = Astro.props;
const t = useTranslations(lang);
const base = getBasePath(lang);

const typesOrder = ['townsfolk', 'outsider', 'minion', 'demon', 'traveller', 'fabled'];

const getCharName = (char: any) => char.data.name?.[lang] || char.data.name?.en || char.id;
const getCharSubtitle = (char: any) => lang === 'en' ? char.data.name?.cn : char.data.name?.en;

// Sort characters initially
const sortedCharacters = [...characters].sort((a, b) => {
  const typeA = a.data.type || 'unknown';
  const typeB = b.data.type || 'unknown';
  
  const idxA = typesOrder.indexOf(typeA);
  const idxB = typesOrder.indexOf(typeB);
  
  if (idxA !== idxB) {
      if (idxA === -1) return 1;
      if (idxB === -1) return -1;
      return idxA - idxB;
  }
  
  return getCharName(a).localeCompare(getCharName(b));
});

// Unique types for filters
const availableTypes = [...new Set(characters.map(c => c.data.type || 'unknown'))].sort((a, b) => {
    const idxA = typesOrder.indexOf(a);
    const idxB = typesOrder.indexOf(b);
    if (idxA === -1 && idxB === -1) return a.localeCompare(b);
    if (idxA === -1) return 1;
    if (idxB === -1) return -1;
    return idxA - idxB;
});

// Translation dictionary for types (fallback to capitalized string)
const typeTranslations: Record<string, any> = {
    'townsfolk': { en: 'Townsfolk', cn: '镇民' },
    'outsider': { en: 'Outsider', cn: '外来者' },
    'minion': { en: 'Minion', cn: '爪牙' },
    'demon': { en: 'Demon', cn: '恶魔' },
    'traveller': { en: 'Traveller', cn: '旅行者' },
    'fabled': { en: 'Fabled', cn: '传奇' },
    'unknown': { en: 'Unknown', cn: '未知' },
};

const getTypeLabel = (type: string) => typeTranslations[type]?.[lang] || type.charAt(0).toUpperCase() + type.slice(1);

const resolveImageSrc = (c: any) => {
  const imgField = c.data?.image;
  // Get the pure ID, ignoring directories (e.g. townsfolk/alchemist -> alchemist)
  const id = c.data?.id || c.id.split('/').pop();
  let p = imgField || `data/assets/tokens/${id}.png`;

  const hasExt = /\.\w{2,5}$/.test(p);
  let candidate = hasExt ? p : `${p}.png`;

  candidate = candidate.replace(/^\/*assets\//, 'data/assets/');
  return getAssetUrl(candidate);
};
---

<div class="character-directory">
  <div class="mb-8 sticky top-0 bg-slate-50/95 backdrop-blur-sm p-4 rounded-xl shadow-sm border border-slate-200 z-10">
    <div class="flex flex-col md:flex-row gap-4 justify-between items-center mb-4">
      <div class="w-full md:w-1/3 relative">
        <input 
          type="text" 
          id="char-search" 
          placeholder={lang === 'cn' ? '搜索角色...' : 'Search characters...'}
          class="w-full pl-10 pr-4 py-2 rounded-lg border border-slate-300 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 shadow-sm transition"
        />
        <svg class="w-5 h-5 absolute left-3 top-2.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </div>
      
      <div class="flex flex-wrap gap-2 w-full md:w-auto" id="type-filters">
        <button data-type="all" class="filter-btn active px-3 py-1 text-sm rounded-full bg-indigo-600 text-white font-medium shadow-sm transition hover:bg-indigo-700">
          {lang === 'cn' ? '全部' : 'All'}
        </button>
        {availableTypes.map(type => (
          <button data-type={type} class="filter-btn px-3 py-1 text-sm rounded-full bg-white text-slate-600 border border-slate-300 font-medium shadow-sm transition hover:bg-slate-50 hover:text-indigo-600">
            {getTypeLabel(type)}
          </button>
        ))}
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6" id="character-grid">
    {sortedCharacters.map(char => {
      const type = char.data.type || 'unknown';
      const name = getCharName(char);
      const subtitle = getCharSubtitle(char);
      const summary = char.data.summary?.[lang] || char.data.summary?.en || '';
      const typeLabel = getTypeLabel(type);
      const imageSrc = resolveImageSrc(char);
      
      return (
        <a
          href={`${base}/characters/${char.id}`}
          class="character-card block bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden hover:shadow-lg hover:border-indigo-400 hover:-translate-y-1 transition-all duration-300"
          data-type={type}
          data-name={name.toLowerCase()}
          data-subtitle={subtitle?.toLowerCase() || ''}
        >
          <div class="w-full h-40 bg-slate-100 overflow-hidden">
            <img src={imageSrc} alt={name} loading="lazy" class="w-full h-full object-cover" onerror="this.style.display='none'" />
          </div>
          <div class="p-5">
            <div class="flex justify-between items-start mb-2">
              <h3 class="font-bold text-xl text-indigo-900 leading-tight">{name}</h3>
              <span class="inline-block px-2 py-1 text-xs font-semibold rounded-md bg-slate-100 text-slate-600 border border-slate-200 whitespace-nowrap ml-2">
                {typeLabel}
              </span>
            </div>

            {subtitle && <p class="text-sm text-slate-500 font-medium mb-3">{subtitle}</p>}

            <p class="text-sm text-slate-600 line-clamp-3 leading-relaxed">
              {summary}
            </p>
          </div>
        </a>
      )
    })}
  </div>
  
  <div id="no-results" class="hidden text-center py-12">
    <p class="text-lg text-slate-500">{lang === 'cn' ? '未找到匹配的角色。' : 'No characters found matching your criteria.'}</p>
  </div>
</div>

<script>
  function setupFilters() {
    const searchInput = document.getElementById('char-search') as HTMLInputElement;
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.character-card');
    const noResults = document.getElementById('no-results');
    
    if (!searchInput) return;

    let currentFilter = 'all';
    let currentSearch = '';

    function filterCards() {
      let visibleCount = 0;
      
      cards.forEach(card => {
        const el = card as HTMLElement;
        const type = el.getAttribute('data-type') || '';
        const name = el.getAttribute('data-name') || '';
        const subtitle = el.getAttribute('data-subtitle') || '';
        
        const matchesType = currentFilter === 'all' || type === currentFilter;
        const matchesSearch = name.includes(currentSearch) || subtitle.includes(currentSearch);
        
        if (matchesType && matchesSearch) {
          el.style.display = 'block';
          visibleCount++;
        } else {
          el.style.display = 'none';
        }
      });
      
      if (noResults) {
        noResults.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    }

    searchInput.addEventListener('input', (e) => {
      currentSearch = (e.target as HTMLInputElement).value.toLowerCase();
      filterCards();
    });

    filterBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const type = target.getAttribute('data-type');
        
        if (type) {
          currentFilter = type;
          
          // Update active states
          filterBtns.forEach(b => {
            b.classList.remove('bg-indigo-600', 'text-white', 'hover:bg-indigo-700');
            b.classList.add('bg-white', 'text-slate-600', 'hover:bg-slate-50', 'hover:text-indigo-600');
          });
          
          target.classList.remove('bg-white', 'text-slate-600', 'hover:bg-slate-50', 'hover:text-indigo-600');
          target.classList.add('bg-indigo-600', 'text-white', 'hover:bg-indigo-700');
          
          filterCards();
        }
      });
    });
  }

  // Astro bundles this script and runs it defer by default
  setupFilters();
  document.addEventListener('astro:page-load', setupFilters);
</script>
