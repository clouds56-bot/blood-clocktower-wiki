---
import { useTranslations, getBasePath, getAssetUrl } from '../i18n/utils';

export interface Props {
  characters: any[];
  lang: 'en' | 'cn';
}

const { characters, lang } = Astro.props;
const { t } = useTranslations(lang);
const base = getBasePath(lang);

const typesOrder = ['townsfolk', 'outsider', 'minion', 'demon', 'traveller', 'fabled'];

const getCharName = (char: any) => char.data.name?.[lang] || char.data.name?.en || char.id;
const getCharSubtitle = (char: any) => lang === 'en' ? char.data.name?.cn : char.data.name?.en;

// Sort characters initially
const sortedCharacters = [...characters].sort((a, b) => {
  const typeA = a.data.type || 'unknown';
  const typeB = b.data.type || 'unknown';
  
  const idxA = typesOrder.indexOf(typeA);
  const idxB = typesOrder.indexOf(typeB);
  
  if (idxA !== idxB) {
      if (idxA === -1) return 1;
      if (idxB === -1) return -1;
      return idxA - idxB;
  }
  
  return getCharName(a).localeCompare(getCharName(b));
});

// Unique types for filters
const availableTypes = [...new Set(characters.map(c => c.data.type || 'unknown'))].sort((a, b) => {
    const idxA = typesOrder.indexOf(a);
    const idxB = typesOrder.indexOf(b);
    if (idxA === -1 && idxB === -1) return a.localeCompare(b);
    if (idxA === -1) return 1;
    if (idxB === -1) return -1;
    return idxA - idxB;
});

// Translation dictionary for types (fallback to capitalized string)
const typeTranslations: Record<string, any> = {
    'townsfolk': { en: 'Townsfolk', cn: '镇民' },
    'outsider': { en: 'Outsider', cn: '外来者' },
    'minion': { en: 'Minion', cn: '爪牙' },
    'demon': { en: 'Demon', cn: '恶魔' },
    'traveller': { en: 'Traveller', cn: '旅行者' },
    'fabled': { en: 'Fabled', cn: '传奇' },
    'unknown': { en: 'Unknown', cn: '未知' },
};

const getTypeLabel = (type: string) => typeTranslations[type]?.[lang] || type.charAt(0).toUpperCase() + type.slice(1);

const resolveImageSrc = (c: any) => {
  const imgField = c.data?.image;
  // Get the pure ID, ignoring directories (e.g. townsfolk/alchemist -> alchemist)
  const id = c.data?.id || c.id.split('/').pop();
  let p = imgField || `assets/tokens/${id}.png`;

  const hasExt = /\.\w{2,5}$/.test(p);
  let candidate = hasExt ? p : `${p}.png`;

  // Normalize any legacy "data/assets/" prefixes to the new "assets/" public path
  candidate = candidate.replace(/^\/*data\/assets\//, 'assets/');
  return getAssetUrl(candidate);
};
---

<div class="character-directory">
  <div class="mb-6 sticky top-4 z-10">
    <div class="surface-panel rounded-2xl px-4 py-4 sm:px-6 sm:py-5">
      <div class="flex flex-col gap-4">
        <div class="flex flex-col sm:flex-row gap-3 items-stretch sm:items-center">
          <div class="flex-1 relative">
            <input
              type="text"
              id="char-search"
              placeholder={lang === 'cn' ? '搜索角色...' : 'Search characters...'}
              class="w-full pl-11 pr-4 py-3 rounded-full bg-[color:var(--bg-800)] border border-[rgba(215,180,106,0.35)] text-[color:var(--ink-50)] placeholder:text-[color:var(--ink-200)] focus:outline-none focus:ring-2 focus:ring-[color:var(--accent-gold)] shadow-sm transition"
            />
            <svg class="w-5 h-5 absolute left-4 top-3.5 text-[color:var(--ink-200)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>
          <div class="flex gap-2">
            <button data-type="all" class="filter-btn active px-4 py-2 rounded-full text-sm font-semibold bg-[color:var(--accent-gold)] text-[#1a141f] shadow-sm transition">
              {lang === 'cn' ? '全部' : 'All'}
            </button>
          </div>
        </div>
        <div class="flex flex-wrap gap-2" id="type-filters">
          {availableTypes.map(type => (
            <button data-type={type} class="filter-btn px-4 py-2 text-sm rounded-full bg-[color:var(--bg-800)] text-[color:var(--ink-200)] border border-[rgba(215,180,106,0.25)] font-medium shadow-sm transition hover:text-[color:var(--accent-gold)]">
              {getTypeLabel(type)}
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5" id="character-grid">
    {sortedCharacters.map(char => {
      const type = char.data.type || 'unknown';
      const name = getCharName(char);
      const subtitle = getCharSubtitle(char);
      const summary = char.data.summary?.[lang] || char.data.summary?.en || '';
      const typeLabel = getTypeLabel(type);
      const imageSrc = resolveImageSrc(char);
      const isGood = ['townsfolk', 'outsider', 'traveller', 'fabled'].includes(type);

      return (
        <a
          href={`${base}/characters/${char.id}`}
          class="character-card group block surface-panel rounded-2xl overflow-hidden hover:-translate-y-1 transition-all duration-300"
          data-type={type}
          data-name={name.toLowerCase()}
          data-subtitle={subtitle?.toLowerCase() || ''}
        >
          <div class="px-4 pt-4">
            <div class={`token-ring mx-auto w-24 h-24 sm:w-28 sm:h-28 rounded-full overflow-hidden bg-[color:var(--bg-700)] flex items-center justify-center border ${isGood ? 'border-[rgba(90,162,255,0.6)]' : 'border-[rgba(255,90,90,0.6)]'}`}>
              <img src={imageSrc} alt={name} loading="lazy" class="w-full h-full object-cover" onerror="this.style.display='none'" />
            </div>
          </div>
          <div class="px-4 pb-5 pt-3 text-center">
            <h3 class="font-display text-lg sm:text-xl text-[color:var(--ink-50)] leading-tight">{name}</h3>
            {subtitle && <p class="text-xs sm:text-sm text-[color:var(--ink-200)] mt-1">{subtitle}</p>}
            <div class="mt-3 flex items-center justify-center gap-2 text-xs uppercase tracking-widest text-[color:var(--ink-200)]">
              <span class={`px-2 py-1 rounded-full border ${isGood ? 'border-[rgba(90,162,255,0.6)] text-[color:var(--accent-blue)]' : 'border-[rgba(255,90,90,0.6)] text-[color:var(--accent-red)]'}`}>
                {typeLabel}
              </span>
            </div>
            {summary && <p class="mt-3 text-xs sm:text-sm text-[color:var(--ink-200)] line-clamp-3 leading-relaxed">{summary}</p>}
          </div>
        </a>
      )
    })}
  </div>

  <div id="no-results" class="hidden text-center py-12">
    <p class="text-lg text-[color:var(--ink-200)]">{lang === 'cn' ? '未找到匹配的角色。' : 'No characters found matching your criteria.'}</p>
  </div>
</div>

<script>
  function setupFilters() {
    const searchInput = document.getElementById('char-search') as HTMLInputElement;
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.character-card');
    const noResults = document.getElementById('no-results');
    
    if (!searchInput) return;

    let currentFilter = 'all';
    let currentSearch = '';

    function filterCards() {
      let visibleCount = 0;
      
      cards.forEach(card => {
        const el = card as HTMLElement;
        const type = el.getAttribute('data-type') || '';
        const name = el.getAttribute('data-name') || '';
        const subtitle = el.getAttribute('data-subtitle') || '';
        
        const matchesType = currentFilter === 'all' || type === currentFilter;
        const matchesSearch = name.includes(currentSearch) || subtitle.includes(currentSearch);
        
        if (matchesType && matchesSearch) {
          el.style.display = 'block';
          visibleCount++;
        } else {
          el.style.display = 'none';
        }
      });
      
      if (noResults) {
        noResults.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    }

    searchInput.addEventListener('input', (e) => {
      currentSearch = (e.target as HTMLInputElement).value.toLowerCase();
      filterCards();
    });

    filterBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const type = target.getAttribute('data-type');
        
        if (type) {
          currentFilter = type;
          
          // Update active states
          filterBtns.forEach(b => {
            b.classList.remove('bg-[color:var(--accent-gold)]', 'text-[#1a141f]');
            b.classList.add('bg-[color:var(--bg-800)]', 'text-[color:var(--ink-200)]');
          });

          target.classList.remove('bg-[color:var(--bg-800)]', 'text-[color:var(--ink-200)]');
          target.classList.add('bg-[color:var(--accent-gold)]', 'text-[#1a141f]');
          
          filterCards();
        }
      });
    });
  }

  // Astro bundles this script and runs it defer by default
  setupFilters();
  document.addEventListener('astro:page-load', setupFilters);
</script>
